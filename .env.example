APP_ENV=local
APP_DEBUG=true

# Base de datos local (Docker Compose)
DB_ENGINE=postgresql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=archery_user
DB_PASSWORD=archery_pass
DB_NAME=archery_training
DATABASE_URL=postgresql+psycopg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# CORS frontend local
# Nota: si necesitas mas origenes, agregalos como JSON valido.
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Auth JWT
JWT_SECRET=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=30
JWT_REFRESH_EXPIRES_MIN=43200

# Referencia para deploy remoto
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# DB_ENGINE=postgresql
